   <item>
    <layout class="QVBoxLayout" name="executeLayout">
     <item>
      <widget class="QPushButton" name="applyButton">
       <property name="enabled">
        <bool>true</bool>
       </property>
       <property name="toolTip">
        <string>Run vascular segmentation (SeqSeg CLI)</string>
       </property>
       <property name="text">
        <string>Run SeqSeg</string>
       </property>
       <property name="minimumSize">
        <size>
         <width>0</width>
         <height>35</height>
        </size>
       </property>
       <property name="styleSheet">
        <string>QPushButton {
    background-color: #4CAF50;
    color: white;
    font-weight: bold;
    border: 2px solid #45a049;
    border-radius: 4px;
    padding: 5px;
}
QPushButton:hover {
    background-color: #45a049;
}
QPushButton:disabled {
    background-color: #cccccc;
    color: #666666;
    border-color: #999999;
}</string>
       </property>
      </widget>
     </item>
     <item>
      <widget class="QLabel" name="statusLabel">
       <property name="text">
        <string>Ready to run vessel segmentation</string>
       </property>
       <property name="alignment">
        <set>Qt::AlignCenter</set>
       </property>
       <property name="styleSheet">
        <string>QLabel {
    color: #666666;
    font-style: italic;
    padding: 5px;
}</string>
       </property>
      </widget>
     </item>
    </layout>
   </item>
   <item>
    <widget class="QLabel" name="instructionsLabel">
     <property name="text">
      <string>Quick start: load a volume, pick or Auto-Create Seeds (two fiducials), set radius, open nnUNet Configuration and click Download Aorta or Download Coronary CT Weights if you need models (buttons fetch and unpack weights—no manual training), set output folder, Run SeqSeg (vessel segmentation). Then use Load Segmentation / Load Surface Mesh / Browse All Output Files.

Details: NIfTI is recommended. Image unit (mm/cm) must match your volume. After the download buttons finish, confirm Train Dataset (Aorta MR/CT is prompted; Coronary uses Dataset010_SEQCOROASOCACT). First run may install dependencies and take longer. Results live under output_directory/output/.</string>
     </property>
     <property name="wordWrap">
      <bool>true</bool>
     </property>
     <property name="alignment">
      <set>Qt::AlignLeading|Qt::AlignLeft|Qt::AlignTop</set>
     </property>
    </widget>
   </item>
   <item>
    <spacer name="verticalSpacer">
     <property name="orientation">
      <enum>Qt::Vertical</enum>
     </property>
     <property name="sizeHint" stdset="0">
      <size>
       <width>20</width>
       <height>40</height>
      </size>
     </property>
    </spacer>
   </item>
  </layout>
 </widget>
