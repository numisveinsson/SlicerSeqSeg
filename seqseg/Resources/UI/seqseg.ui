 <resources/>
 <connections>
  <connection>
   <sender>seqseg</sender>
   <signal>mrmlSceneChanged(vtkMRMLScene*)</signal>
   <receiver>inputSelector</receiver>
   <slot>setMRMLScene(vtkMRMLScene*)</slot>
   <hints>
    <hint type="sourcelabel">
     <x>200</x>
     <y>250</y>
    </hint>
    <hint type="destinationlabel">
     <x>300</x>
     <y>50</y>
    </hint>
   </hints>
  </connection>
  <connection>
   <sender>seqseg</sender>
   <signal>mrmlSceneChanged(vtkMRMLScene*)</signal>
   <receiver>seedPoint1Selector</receiver>
   <slot>setMRMLScene(vtkMRMLScene*)</slot>
   <hints>
    <hint type="sourcelabel">
     <x>200</x>
     <y>250</y>
    </hint>
    <hint type="destinationlabel">
     <x>300</x>
     <y>80</y>
    </hint>
   </hints>
  </connection>
  <connection>
   <sender>seqseg</sender>
   <signal>mrmlSceneChanged(vtkMRMLScene*)</signal>
   <receiver>seedPoint2Selector</receiver>
   <slot>setMRMLScene(vtkMRMLScene*)</slot>
   <hints>
    <hint type="sourcelabel">
     <x>200</x>
     <y>250</y>
    </hint>
    <hint type="destinationlabel">
     <x>300</x>
     <y>110</y>
    </hint>
   </hints>
  </connection>
  <connection>
   <sender>seqseg</sender>
   <signal>mrmlSceneChanged(vtkMRMLScene*)</signal>
   <receiver>outputSegmentationSelector</receiver>
   <slot>setMRMLScene(vtkMRMLScene*)</slot>
   <hints>
    <hint type="sourcelabel">
     <x>200</x>
     <y>250</y>
    </hint>
    <hint type="destinationlabel">
     <x>300</x>
     <y>170</y>
    </hint>
   </hints>
  </connection>
 </connections>
